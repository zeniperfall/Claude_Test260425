# --- Optional API keys (모두 무료 발급 가능) ---
# Yahoo Finance: 키 불필요 (yahoo-finance2 패키지 사용)

# Finnhub - 미국 종목 실시간 시세 + 뉴스 (60 req/min)
# https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage - 기술지표 (RSI/MACD/SMA), 무료 25 req/day
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# NewsAPI - 한/중 종목 뉴스 (100 req/day)
# https://newsapi.org/register
NEWSAPI_KEY=

# 한국투자증권 KIS Open API - 한국 주식 실시간 시세 (정확도 ↑)
# https://apiportal.koreainvestment.com 가입 후 앱 등록
# 모의투자: https://openapivts.koreainvestment.com:29443
# 실전투자: https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Supabase - 로그인 + 워치리스트 클라우드 동기화 (선택)
# https://supabase.com 프로젝트 생성 후 Settings → API에서 복사
# 미설정 시 자동으로 로컬(localStorage) 모드로 동작
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
